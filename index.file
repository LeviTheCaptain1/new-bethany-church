<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Community Hope Center</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, sans-serif;
}

body{
    line-height:1.6;
    color:#333;
}

header{
    background:#0b5ed7;
    color:white;
    padding:20px 8%;
    display:flex;
    justify-content:space-between;
    align-items:center;
}

.logo{
    font-size:24px;
    font-weight:bold;
}

nav a{
    color:white;
    text-decoration:none;
    margin-left:20px;
}

.hero{
    background:linear-gradient(rgba(0,0,0,.5), rgba(0,0,0,.5)),
    url('https://images.unsplash.com/photo-1517486808906-6ca8b3f04846?auto=format&fit=crop&w=1600&q=80');
    background-size:cover;
    background-position:center;
    height:90vh;
    color:white;
    display:flex;
    justify-content:center;
    align-items:center;
    text-align:center;
    padding:20px;
}

.hero-content h1{
    font-size:3rem;
    margin-bottom:15px;
}

.hero-content p{
    max-width:700px;
    margin:auto;
    margin-bottom:25px;
}

.btn{
    display:inline-block;
    padding:14px 30px;
    background:#ff6b35;
    color:white;
    text-decoration:none;
    border-radius:5px;
    font-weight:bold;
}

.btn:hover{
    background:#e85b2a;
}

section{
    padding:70px 8%;
}

.section-title{
    text-align:center;
    margin-bottom:40px;
    color:#0b5ed7;
}

.about{
    text-align:center;
    max-width:900px;
    margin:auto;
}

.services{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
    gap:20px;
}

.card{
    background:#f4f4f4;
    padding:25px;
    border-radius:10px;
}

.stats{
    background:#0b5ed7;
    color:white;
}

.stats-grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(180px,1fr));
    gap:20px;
    text-align:center;
}

.stat h2{
    font-size:2rem;
}

.donate{
    text-align:center;
    background:#f8f9fa;
}

.contact{
    text-align:center;
}

footer{
    background:#222;
    color:white;
    text-align:center;
    padding:20px;
}

@media(max-width:768px){
    .hero-content h1{
        font-size:2rem;
    }

    header{
        flex-direction:column;
        gap:10px;
    }
}
</style>
</head>

<body>

<header>
    <div class="logo">Community Hope</div>

    <nav>
        <a href="#about">About</a>
        <a href="#services">Services</a>
        <a href="#donate">Donate</a>
        <a href="#contact">Contact</a>
    </nav>
</header>

<section class="hero">
    <div class="hero-content">
        <h1>A Community of Hope & Support</h1>
        <p>
            Helping individuals and families overcome hunger,
            homelessness, and poverty through compassionate services.
        </p>

        <!-- DONATE BUTTON -->
        <a href="https://your-donation-link.com" class="btn">
            Donate Now
        </a>
    </div>
</section>

<section id="about">
    <h2 class="section-title">About Us</h2>

    <div class="about">
        <p>
            We provide support, dignity, and opportunities to people
            experiencing hardship. Our mission is to build stronger
            communities through food assistance, housing support,
            wellness programs, and financial guidance.
        </p>
    </div>
</section>

<section id="services">
    <h2 class="section-title">How We Help</h2>

    <div class="services">

        <div class="card">
            <h3>Food Assistance</h3>
            <p>Providing meals and groceries to families in need.</p>
        </div>

        <div class="card">
            <h3>Housing Support</h3>
            <p>Helping individuals find stable housing solutions.</p>
        </div>

        <div class="card">
            <h3>Wellness Programs</h3>
            <p>Offering resources that support physical and mental health.</p>
        </div>

        <div class="card">
            <h3>Financial Guidance</h3>
            <p>Helping people achieve long-term self-sufficiency.</p>
        </div>

    </div>
</section>

<section class="stats">
    <h2 class="section-title" style="color:white;">Our Impact</h2>

    <div class="stats-grid">

        <div class="stat">
            <h2>225K+</h2>
            <p>Meals Served</p>
        </div>

        <div class="stat">
            <h2>1,500+</h2>
            <p>Showers Provided</p>
        </div>

        <div class="stat">
            <h2>880+</h2>
            <p>Families Assisted</p>
        </div>

        <div class="stat">
            <h2>3,200+</h2>
            <p>Shelter Nights</p>
        </div>

    </div>
</section>

<section id="donate" class="donate">
    <h2 class="section-title">Support Our Mission</h2>

    <p style="margin-bottom:25px;">
        Every donation helps provide food, shelter, and hope.
    </p>

    <a href="https://your-donation-link.com" class="btn">
        Donate Today
    </a>
</section>

<section id="contact" class="contact">
    <h2 class="section-title">Contact Us</h2>

    <p>Email: info@example.org</p>
    <p>Phone: (555) 123-4567</p>
    <p>Address: 123 Community Street</p>
</section>

<footer>
    <p>© 2026 Community Hope. All Rights Reserved.</p>
</footer>

</body>
</html>
